# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Claude API (Anthropic) - AI Content Generation (optional)
CLAUDE_API_KEY=sk-ant-api03-your-claude-api-key
CLAUDE_MODEL=claude-3-sonnet-20240229

# SEMrush API - SEO Data (optional)
SEMRUSH_API_KEY=your_semrush_api_key

# Google Search Console API (optional)
GSC_CLIENT_EMAIL=your-service-account@gsc-project.iam.gserviceaccount.com
GSC_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Email Configuration (SMTP) - optional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=SEO Automation

# Puppeteer / Crawler
CRAWL_MAX_PAGES=50
CRAWL_CONCURRENCY=5

# Scheduler
ENABLE_CRON_JOBS=false

# Mock Data Fallback (set to true if no real API keys)
USE_MOCK_DATA=true

# Local demo login created automatically when USE_MOCK_DATA=true
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=Password123!
